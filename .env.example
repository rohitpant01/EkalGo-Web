# ============================================
# EkalGo Web — Environment Variables
# ============================================
# Copy this file to .env and fill in your keys
# cp .env.example .env

# ---- AI API (Google Gemini) ----
# Get from: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# ---- Google Places API ----
VITE_GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# ---- Groq API (High Speed Llama) ----
# Get from: https://console.groq.com/keys
VITE_GROQ_API_KEY=your_groq_api_key_here

# ---- App Config ----
VITE_APP_NAME=EkalGo
VITE_PLAY_STORE_URL=https://play.google.com/store/apps/details?id=com.ekalgo.app
VITE_APP_STORE_URL=https://apps.apple.com/app/ekalgo/id000000000

# ---- Image Fallback APIs (Pexels & Pixabay) ----
VITE_PEXELS_API_KEY=your_pexels_api_key_here
VITE_PIXABAY_API_KEY=your_pixabay_api_key_here
